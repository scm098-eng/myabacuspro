
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information including role and practice stats.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "surname": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "teacher", "admin"] },
        "subscriptionStatus": { "type": "string", "enum": ["free", "pro"] },
        "subscriptionType": { "type": "string", "enum": ["none", "recurring", "one-time", "gift"] },
        "subscriptionExpiry": { "type": "string", "format": "date-time" },
        "totalPoints": { "type": "number" },
        "totalDaysPracticed": { "type": "number" },
        "isSuspended": { "type": "boolean" },
        "isAdminRead": { "type": "boolean", "description": "Whether the admin has acknowledged this new signup." }
      },
      "required": ["uid", "email", "role"]
    },
    "Coupon": {
      "title": "Coupon",
      "description": "Gift codes for Pro access.",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "durationDays": { "type": "number" },
        "isUsed": { "type": "boolean" },
        "usedBy": { "type": "string" },
        "usedAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["code", "durationDays", "isUsed"]
    },
    "ExamApplication": {
      "title": "ExamApplication",
      "description": "Student request to participate in an official exam group.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "studentName": { "type": "string" },
        "group": { "type": "string", "enum": ["A", "B", "C", "D"] },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "appliedAt": { "type": "string", "format": "date-time" },
        "age": { "type": "number" },
        "timeLimit": { "type": "number", "description": "Calculated based on age" }
      }
    },
    "ExamResult": {
      "title": "ExamResult",
      "description": "Record of a completed exam paper.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "studentName": { "type": "string" },
        "paperId": { "type": "string" },
        "group": { "type": "string" },
        "score": { "type": "number" },
        "totalQuestions": { "type": "number" },
        "accuracy": { "type": "number" },
        "isFinal": { "type": "boolean" },
        "resultDeclared": { "type": "boolean", "description": "Whether the result is released to the student." },
        "rank": { "type": "number", "description": "Official rank assigned by admin (1, 2, 3, etc.)" },
        "submittedAt": { "type": "string", "format": "date-time" },
        "timeLeft": { "type": "number" }
      }
    },
    "TestResult": {
      "title": "TestResult",
      "description": "Record of a completed practice test.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "testId": { "type": "string" },
        "score": { "type": "number" },
        "accuracy": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "BlogPost": {
      "title": "BlogPost",
      "description": "An article published on the site blog.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "content": { "type": "string", "description": "HTML content of the post" },
        "excerpt": { "type": "string" },
        "category": { "type": "string" },
        "author": { "type": "string" },
        "image": { "type": "string", "description": "URL to the featured image" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "slug", "content", "category"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/backend/entities/UserProfile",
      "description": "User profiles and statistics."
    },
    "/coupons/{code}": {
      "schema": "#/backend/entities/Coupon",
      "description": "Gift codes for Pro access."
    },
    "/examApplications/{appId}": {
      "schema": "#/backend/entities/ExamApplication",
      "description": "Applications for official exams."
    },
    "/examResults/{resultId}": {
      "schema": "#/backend/entities/ExamResult",
      "description": "Official exam and practice paper results."
    },
    "/testResults/{resultId}": {
      "schema": "#/backend/entities/TestResult",
      "description": "History of practice test performance."
    },
    "/gameProgress/{userId}": {
      "schema": { "type": "object", "properties": { "completedLevels": { "type": "array", "items": { "type": "number" } } } },
      "description": "Tracking of unlocked and completed game levels."
    },
    "/blogs/{blogId}": {
      "schema": "#/backend/entities/BlogPost",
      "description": "Content for the site's blog section."
    },
    "/stats/leaderboard": {
      "schema": { "type": "object" },
      "description": "System-wide statistics and weekly winners."
    }
  }
}
