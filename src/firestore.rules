
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // --- HELPER FUNCTIONS ---
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isAdmin() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'student') == 'admin';
    }

    function isTeacher() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'student') == 'teacher';
    }

    function isNotSuspended() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isSuspended', false) != true;
    }

    // --- USER PROFILE RULES ---
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if isOwner(userId);
      allow update: if isAdmin() || (isOwner(userId) && 
        isNotSuspended() &&
        !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['role', 'status', 'subscriptionStatus', 'isSuspended']));
      allow delete: if isAdmin();
      allow list: if request.auth != null;
    }
    
    // --- EXAM RULES ---
    match /examApplications/{appId} {
      allow read, list: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin() || isTeacher());
      allow create: if request.auth != null && isNotSuspended() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      // Allow student to delete their own application (used for re-applying after rejection)
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /examResults/{resultId} {
      // Allow students to see their own attempts list and metadata.
      // Content visibility is managed in the UI (Final scores only visible to Admin).
      allow list, read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin() || isTeacher());
      allow create: if request.auth != null && isNotSuspended() && request.resource.data.userId == request.auth.uid;
    }
    
    // --- BLOG RULES ---
    match /blogs/{blogId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // --- GAME & TEST PROGRESS ---
    match /testResults/{resultId} {
      allow create: if request.auth != null && 
                    isNotSuspended() &&
                    request.resource.data.userId == request.auth.uid;
      
      allow read, list: if request.auth != null && 
                        (request.auth.uid == resource.data.userId || isAdmin() || isTeacher());
    }
    
    match /gameProgress/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) && isNotSuspended();
    }

    match /stats/leaderboard {
      allow read: if true;
    }

    match /stats/{statId} {
      allow read: if request.auth != null && (isAdmin() || isTeacher());
      allow write: if false;
    }
  }
}
