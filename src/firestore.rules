
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper function to check ownership
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Helper function to check for admin role
    function isAdmin() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper function to check for teacher role
    function isTeacher() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if isOwner(userId);
      allow update: if isAdmin() || (isOwner(userId) && 
        resource.data.isSuspended != true &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'status', 'subscriptionStatus', 'isSuspended']));
      allow delete: if isAdmin();
      allow list: if request.auth != null && (
        isAdmin() || 
        isTeacher() || 
        (request.query.limit <= 10) ||
        (request.query.where[0] == 'role' && request.query.where[1] == '==' && request.query.where[2] == 'teacher' && request.query.where[3] == 'status' && request.query.where[4] == '==' && request.query.where[5] == 'approved')
      );
    }
    
    match /testResults/{resultId} {
      allow create: if request.auth != null && 
                      request.resource.data.userId == request.auth.uid &&
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isSuspended != true;
      allow read, list: if request.auth != null && 
                          (isOwner(resource.data.userId) || isAdmin() || isTeacher());
    }
    
    match /gameProgress/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isSuspended != true;
    }

    match /stats/{statId} {
      allow read: if request.auth != null && (isAdmin() || isTeacher());
      allow write: if false;
    }

    match /processedWebhooks/{eventId} {
      allow read: if request.auth != null && isAdmin();
      allow write: if false;
    }
  }
}
