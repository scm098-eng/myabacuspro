
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // --- HELPER FUNCTIONS ---
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isAdmin() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'student') == 'admin';
    }

    function isTeacher() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'student') == 'teacher';
    }

    function isNotSuspended() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isSuspended', false) != true;
    }

    // --- USER PROFILE RULES ---
    match /users/{userId} {
      // Allow authenticated users to read profiles for leaderboards
      allow read: if request.auth != null;
      
      allow create: if isOwner(userId);

      allow update: if isAdmin() || (isOwner(userId) && 
        resource.data.get('isSuspended', false) != true &&
        !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['role', 'status', 'subscriptionStatus', 'isSuspended']));

      allow delete: if isAdmin();
      
      allow list: if request.auth != null;
    }
    
    // --- GAME & TEST PROGRESS ---
    match /testResults/{resultId} {
      allow create: if request.auth != null && 
                    isNotSuspended() &&
                    request.resource.data.userId == request.auth.uid;
      
      allow read, list: if request.auth != null && 
                        (isOwner(resource.data.userId) || isAdmin() || isTeacher());
    }
    
    match /gameProgress/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) && isNotSuspended();
    }

    // --- SYSTEM DATA ---
    match /stats/leaderboard {
      // Winner status is PUBLIC so everyone can see the champion on the scrolling marquee
      allow read: if true;
    }

    match /stats/{statId} {
      allow read: if request.auth != null && (isAdmin() || isTeacher());
      allow write: if false;
    }

    match /processedWebhooks/{eventId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
