
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // --- HELPER FUNCTIONS ---
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isAdmin() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'student') == 'admin';
    }

    function isTeacher() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'student') == 'teacher';
    }

    // Helper to check if user is suspended
    function isNotSuspended() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isSuspended', false) != true;
    }

    // --- USER PROFILE RULES ---
    match /users/{userId} {
      // Allow authenticated users to read profiles for leaderboards and directories
      allow read: if request.auth != null;
      
      allow create: if isOwner(userId);

      // Rule for Profile Updates:
      // Owners can update points/streaks only if NOT suspended.
      // Owners CANNOT change their role, status, or subscription.
      allow update: if isAdmin() || (isOwner(userId) && 
        isNotSuspended() &&
        !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['role', 'status', 'subscriptionStatus', 'isSuspended']));

      allow delete: if isAdmin();
      
      // Required for real-time dashboard listeners and search
      allow list: if request.auth != null;
    }
    
    // --- BLOG RULES ---
    match /blogs/{blogId} {
      // Blogs are public for all visitors to read
      allow read: if true;
      // Only admins can create, edit, or delete blog content
      allow write: if isAdmin();
    }
    
    // --- GAME & TEST PROGRESS ---
    match /testResults/{resultId} {
      allow create: if request.auth != null && 
                    isNotSuspended() &&
                    request.resource.data.userId == request.auth.uid;
      
      allow read, list: if request.auth != null && 
                        (request.auth.uid == resource.data.userId || isAdmin() || isTeacher());
    }
    
    match /gameProgress/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) && isNotSuspended();
    }

    // --- SYSTEM DATA ---
    match /stats/leaderboard {
      // Winner status is PUBLIC so everyone can see the champion on the scrolling marquee
      allow read: if true;
    }

    match /stats/{statId} {
      // Internal system statistics are restricted to staff
      allow read: if request.auth != null && (isAdmin() || isTeacher());
      allow write: if false;
    }

    match /processedWebhooks/{eventId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
