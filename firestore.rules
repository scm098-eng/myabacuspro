
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // --- HELPER FUNCTIONS ---
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isAdmin() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'student') == 'admin';
    }

    function isTeacher() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'student') == 'teacher';
    }

    function isNotSuspended() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isSuspended', false) != true;
    }

    // --- USER PROFILE RULES ---
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if isOwner(userId);
      allow update: if isAdmin() || (isOwner(userId) && 
        isNotSuspended() &&
        !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['role', 'status', 'subscriptionStatus', 'isSuspended']));
      allow delete: if isAdmin();
      allow list: if request.auth != null;
    }

    // --- COUPON RULES ---
    match /coupons/{code} {
      // Locked down. Redemption is handled via secure Cloud Functions (Admin SDK).
      allow read, write: if false;
    }
    
    // --- EXAM RULES ---
    match /examApplications/{appId} {
      allow read, list: if request.auth != null && (appId == request.auth.uid || resource.data.userId == request.auth.uid || isAdmin() || isTeacher());
      allow create: if request.auth != null && isNotSuspended() && (appId == request.auth.uid || request.resource.data.userId == request.auth.uid);
      allow update: if isAdmin();
      // allow-reapply: Administrators can delete applications to trigger a dashboard reset
      allow delete: if isAdmin() || (request.auth != null && (appId == request.auth.uid || resource.data.userId == request.auth.uid));
    }

    match /examResults/{resultId} {
      // Allow students to see their own attempts list and metadata.
      allow list, read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin() || isTeacher());
      allow create: if request.auth != null && isNotSuspended() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      // Allow Admin to clear results for a new schedule cycle
      allow delete: if isAdmin();
    }
    
    // --- BLOG RULES ---
    match /blogs/{blogId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // --- GAME & TEST PROGRESS ---
    match /testResults/{resultId} {
      allow create: if request.auth != null && 
                    isNotSuspended() &&
                    request.resource.data.userId == request.auth.uid;
      
      allow read, list: if request.auth != null && 
                        (request.auth.uid == resource.data.userId || isAdmin() || isTeacher());
    }
    
    // --- GAME PROGRESS ---
    match /gameProgress/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) && isNotSuspended();
    }

    // --- SYSTEM STATS & LEADERBOARD ---
    match /stats/leaderboard {
      allow read: if true;
    }

    match /stats/examSchedule {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /stats/{statId} {
      allow read: if request.auth != null && (isAdmin() || isTeacher());
      allow write: if false;
    }
    
    // Deployment trigger nudge: 2026-06-18T14:45:00Z - Synchronizing robust student ID listeners and admin cancellation permissions.
  }
}
